  create view "airflow"."dbt_weather_restaurants"."stg_restaurants__dbt_tmp"
    
    
  as (
    -- Staging: normalize OpenStreetMap restaurant data



SELECT
    osm_id::bigint                                      AS restaurant_id,
    city_key,
    city_name,
    COALESCE(NULLIF(TRIM(name), ''), 'Unknown')         AS restaurant_name,
    CASE amenity
