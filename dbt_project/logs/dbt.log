    (ingested_at AT TIME ZONE 'UTC')::timestamp         AS ingested_at_utc
FROM "airflow"."dbt_weather_restaurants"."restaurants_raw"
WHERE osm_id IS NOT NULL
  AND latitude IS NOT NULL
  AND longitude IS NOT NULL
  );
